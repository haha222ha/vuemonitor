{
  "name": "xhs365-client",
  "version": "0.1.0",
  "private": true,
  "description": "XHS365 AI E-commerce Monitoring Platform - Electron Client",
  "author": "XHS365",
  "main": "dist/main/index.js",
  "scripts": {
    "dev:main": "vite --mode main",
    "dev:preload": "vite --mode preload",
    "dev:renderer": "vite",
    "dev:electron": "node scripts/dev.js",
    "build:main": "vite build --config vite.config.main.mts",
    "build:preload": "vite build --config vite.config.preload.mts",
    "build:renderer": "vite build --config vite.config.mts",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "dist": "npm run build && electron-builder",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@electron/remote": "^2.1.0",
    "axios": "^1.16.0",
    "echarts": "^5.6.0",
    "electron-updater": "^6.8.3",
    "element-plus": "^2.14.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "pinia": "^2.3.1",
    "playwright": "^1.44.0",
    "playwright-core": "^1.59.1",
    "sql.js": "^1.14.1",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4",
    "vuedraggable": "^4.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "canvas": "^3.2.3",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.1",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^1.6.1",
    "vue-tsc": "^2.2.12",
    "ws": "^8.20.0"
  },
  "build": {
    "appId": "com.xhs365.client",
    "productName": "XHS365",
    "copyright": "Copyright © 2026 XHS365",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "build/icon.png",
      "!src",
      "!release"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "XHS365-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "XHS365",
      "perMachine": false,
      "allowElevation": true
    },
    "asar": true,
    "asarUnpack": [
      "**/*.wasm",
      "**/node_modules/sql.js/**/*",
      "**/node_modules/playwright-core/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "xhs365",
      "repo": "client"
    }
  }
}
