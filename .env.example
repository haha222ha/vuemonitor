# ============================================================
# XHS365 环境变量配置
# 复制此文件为 .env 并填写实际值
# ============================================================

# --- 安全密钥（生产环境必须修改！）---
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string-at-least-32-chars
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# --- AI 服务 ---
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# --- SMTP 邮件 ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@xhs365.cn

# --- 数据库（Docker 环境下由 docker-compose 覆盖）---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vuemonitor
DB_USER=saas_user
DB_PASSWORD=saas_pass

# --- Redis（Docker 环境下由 docker-compose 覆盖）---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=

# --- 应用配置 ---
DEBUG=false
CORS_ORIGINS=["http://localhost","http://localhost:5173","http://localhost:5174","http://localhost:3000"]
