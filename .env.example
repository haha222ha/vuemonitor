# ============================================================
# XHS365 环境变量配置
# 复制此文件为 .env 并填写实际值
# ============================================================

# --- 应用 ---
APP_NAME=XHS365
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=production

# --- 安全密钥（必须修改！使用 python -c "import secrets; print(secrets.token_urlsafe(48))" 生成）---
JWT_SECRET=
JWT_REFRESH_SECRET=
ENCRYPTION_KEY=

# --- 数据库 ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=vuemonitor
DB_USER=saas_user
# [必须修改] 使用 python -c "import secrets; print(secrets.token_urlsafe(24))" 生成
DB_PASSWORD=

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
# [必须修改] 使用 python -c "import secrets; print(secrets.token_urlsafe(24))" 生成
REDIS_PASSWORD=

# --- AI 服务 ---
AI_DEFAULT_PROVIDER=deepseek
AI_DEFAULT_MODEL=deepseek-v4-flash
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# --- SMTP 邮件 ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@xhs365.cn
SMTP_USE_TLS=true

# --- CORS ---
# 生产环境自动过滤 localhost，请添加实际域名
CORS_ORIGINS=["https://www.xhs365.cn","https://xhs365.cn","https://admin.xhs365.cn"]

# --- 日志 ---
LOG_LEVEL=warning
LOG_FORMAT=json
