{
  "manifest_version": 3,
  "name": "流量蜂小红书数据监控助手",
  "version": "2.0.0",
  "description": "自动提取小红书商品销量和店铺销量数据，支持侧边栏快速查看",
  
  "permissions": [
    "activeTab",
    "sidePanel",
    "storage",
    "tabs",
    "windows",
    "notifications",
    "alarms",
    "scripting"
  ],
  
  "host_permissions": [
    "https://www.xiaohongshu.com/*",
    "https://xiaohongshu.com/*",
    "https://unpkg.com/*"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["https://www.xiaohongshu.com/*", "https://xiaohongshu.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  
  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "incognito": "spanning",
  
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "小红书数据监控",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  
  "web_accessible_resources": [
    {
      "resources": [
        "lib/*.js", 
        "data-manager.html", 
        "data-manager.css", 
        "data-manager.js",
        "data-manager-modal.css",
        "data-manager-monitor.css",
        "fix-data-mapping.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  
  "minimum_chrome_version": "88"
}