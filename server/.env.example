# ============================================================
# XHS365 环境变量配置模板
# 复制此文件为 .env 并修改所有标记为 [必须修改] 的值
# ============================================================

# ===== 应用 =====
APP_NAME=VueMonitor
APP_VERSION=0.1.0
DEBUG=true

# ===== 数据库 =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vuemonitor
DB_USER=saas_user
DB_PASSWORD=saas_pass

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379

# ===== JWT 密钥 [必须修改] =====
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== 数据加密密钥 [必须修改] =====
# 生成方法: python -c "import secrets; print(secrets.token_hex(16))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# ===== AI 服务（按需配置） =====
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# ===== 邮件服务（按需配置） =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@xhs365.cn

# ===== CORS =====
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174"]
