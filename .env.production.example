# ============================================================
# XHS365 生产环境配置
# 复制为 .env.production 并填写真实值
# ============================================================

ENVIRONMENT=production
DEBUG=false

# --- 安全密钥（必须修改！使用 python -c "import secrets; print(secrets.token_hex(32))" 生成）---
JWT_SECRET=
JWT_REFRESH_SECRET=
ENCRYPTION_KEY=

# --- 数据库 ---
DB_HOST=
DB_PORT=5432
DB_NAME=vuemonitor
DB_USER=
DB_PASSWORD=

# --- Redis ---
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# --- AI 服务 ---
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# --- SMTP 邮件 ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@xhs365.cn
SMTP_USE_TLS=true

# --- CORS ---
CORS_ORIGINS=["https://your-domain.com"]

# --- 日志 ---
LOG_LEVEL=warning
LOG_FORMAT=json
